/**
 * game.wxss - 游戏页面样式
 * 暗色主题，rpx 单位
 */

/* ===== 页面容器 ===== */
.game-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #0f0f23;
  overflow: hidden;
}

/* ===== 顶部信息栏 ===== */
.info-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background: linear-gradient(180deg, #1a1a3e 0%, #16163a 100%);
  border-bottom: 2rpx solid #2a2a5e;
  min-height: 80rpx;
  flex-shrink: 0;
}

.level-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #e0e0ff;
  letter-spacing: 2rpx;
}

.step-info {
  font-size: 28rpx;
  color: #8888cc;
  background: rgba(255, 255, 255, 0.06);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* ===== 游戏画布 ===== */
.game-canvas {
  flex: 1;
  width: 100%;
  background-color: #0f0f23;
}

/* ===== 底部工具栏 ===== */
.toolbar {
  display: flex;
  flex-direction: column;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(0deg, #12122e 0%, #1a1a3e 100%);
  border-top: 2rpx solid #2a2a5e;
  flex-shrink: 0;
  gap: 16rpx;
}

/* ===== 物品调色板 ===== */
.item-palette {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.item-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.item-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  border-radius: 16rpx 16rpx 0 0;
}

/* 传送带 - 蓝色 */
.item-btn:nth-child(1)::before {
  background: #2196f3;
}
.item-btn:nth-child(1) .item-label {
  color: #64b5f6;
}
.item-btn:nth-child(1).active {
  background: rgba(33, 150, 243, 0.15);
  border-color: #2196f3;
  box-shadow: 0 0 20rpx rgba(33, 150, 243, 0.3);
}

/* 弹簧 - 橙色 */
.item-btn:nth-child(2)::before {
  background: #ff5722;
}
.item-btn:nth-child(2) .item-label {
  color: #ff8a65;
}
.item-btn:nth-child(2).active {
  background: rgba(255, 87, 34, 0.15);
  border-color: #ff5722;
  box-shadow: 0 0 20rpx rgba(255, 87, 34, 0.3);
}

/* 斜坡 - 紫色 */
.item-btn:nth-child(3)::before {
  background: #9c27b0;
}
.item-btn:nth-child(3) .item-label {
  color: #ce93d8;
}
.item-btn:nth-child(3).active {
  background: rgba(156, 39, 176, 0.15);
  border-color: #9c27b0;
  box-shadow: 0 0 20rpx rgba(156, 39, 176, 0.3);
}

.item-btn.active {
  transform: scale(1.05);
}

.item-btn.disabled {
  opacity: 0.35;
  pointer-events: none;
}

.item-label {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.item-count {
  font-size: 22rpx;
  color: #888;
}

/* ===== 方向选择器 (十字键) ===== */
.dir-selector {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
  animation: fadeIn 0.2s ease;
}

.dir-row {
  display: flex;
  gap: 80rpx;
}

.dir-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  transition: all 0.15s ease;
}

.dir-btn:active {
  background: rgba(233, 30, 99, 0.3);
  border-color: #e91e63;
  transform: scale(0.92);
}

.dir-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: bold;
}

/* ===== 操作按钮行 ===== */
.action-bar {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  max-width: 180rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: all 0.15s ease;
  border: 2rpx solid transparent;
}

.action-btn:active {
  transform: scale(0.95);
}

/* 发射按钮 */
.action-btn.launch {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  color: #fff;
  border-color: #4caf50;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
}

.action-btn.launch:active {
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

/* 重置按钮 */
.action-btn.reset {
  background: rgba(255, 152, 0, 0.12);
  color: #ffb74d;
  border-color: rgba(255, 152, 0, 0.3);
}

.action-btn.reset:active {
  background: rgba(255, 152, 0, 0.25);
}

/* 清空按钮 */
.action-btn.clear {
  background: rgba(244, 67, 54, 0.12);
  color: #ef9a9a;
  border-color: rgba(244, 67, 54, 0.3);
}

.action-btn.clear:active {
  background: rgba(244, 67, 54, 0.25);
}

/* 返回按钮 */
.action-btn.back {
  background: rgba(255, 255, 255, 0.06);
  color: #aaa;
  border-color: rgba(255, 255, 255, 0.1);
}

.action-btn.back:active {
  background: rgba(255, 255, 255, 0.12);
}

/* ===== 结果弹窗 ===== */
.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(12px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.result-card {
  width: 560rpx;
  padding: 60rpx 40rpx 48rpx;
  border-radius: 32rpx;
  text-align: center;
  animation: slideUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.result-card.success {
  background: linear-gradient(160deg, #1b3a2a 0%, #0f2318 100%);
  border: 2rpx solid rgba(76, 175, 80, 0.4);
  box-shadow: 0 16rpx 60rpx rgba(76, 175, 80, 0.2);
}

.result-card.fail {
  background: linear-gradient(160deg, #3a1b1b 0%, #230f0f 100%);
  border: 2rpx solid rgba(244, 67, 54, 0.4);
  box-shadow: 0 16rpx 60rpx rgba(244, 67, 54, 0.2);
}

.result-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.result-card.success .result-title {
  color: #81c784;
}

.result-card.fail .result-title {
  color: #ef9a9a;
}

/* 星星评价 */
.result-stars {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.star {
  font-size: 52rpx;
  color: rgba(255, 255, 255, 0.15);
  transition: all 0.3s ease;
}

.star.active {
  color: #ffd54f;
  text-shadow: 0 0 20rpx rgba(255, 213, 79, 0.5);
  animation: starPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.star.active:nth-child(2) {
  animation-delay: 0.1s;
}

.star.active:nth-child(3) {
  animation-delay: 0.2s;
}

/* 结果按钮 */
.result-btns {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.result-btn {
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.15s ease;
  background: rgba(255, 255, 255, 0.08);
  color: #ccc;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.result-btn:active {
  transform: scale(0.96);
}

.result-btn.primary {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  color: #fff;
  border-color: #4caf50;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.3);
}

.result-btn.primary:active {
  box-shadow: 0 2rpx 10rpx rgba(76, 175, 80, 0.2);
}

/* ===== 动画 ===== */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(60rpx) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes starPop {
  0% {
    transform: scale(0);
  }
  60% {
    transform: scale(1.3);
  }
  100% {
    transform: scale(1);
  }
}