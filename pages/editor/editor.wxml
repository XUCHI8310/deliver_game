<view class="editor-page">
  <!-- 顶部工具栏 -->
  <view class="top-bar">
    <input class="name-input" value="{{levelName}}" bindinput="onNameInput" placeholder="关卡名称" />
    <view class="size-ctrl">
      <text>宽</text>
      <picker range="{{sizeRange}}" value="{{gridWidthIdx}}" bindchange="onWidthChange">
        <text class="picker-val">{{gridWidth}}</text>
      </picker>
      <text>高</text>
      <picker range="{{sizeRange}}" value="{{gridHeightIdx}}" bindchange="onHeightChange">
        <text class="picker-val">{{gridHeight}}</text>
      </picker>
    </view>
    <view class="top-actions">
      <view class="btn-test" bindtap="onTest">▶ 测试</view>
      <view class="btn-save" bindtap="onSave">💾 保存</view>
    </view>
  </view>

  <!-- 编辑画布 -->
  <canvas 
    type="2d"
    id="editorCanvas"
    class="editor-canvas"
    bindtouchstart="onCanvasTap"
    bindlongpress="onCanvasLongPress"
  ></canvas>

  <!-- 底部工具面板 -->
  <view class="palette">
    <!-- 格子工具 -->
    <view class="palette-section">
      <text class="palette-title">格子</text>
      <view class="tool-list">
        <view class="tool-btn {{currentTool === 'empty' ? 'active' : ''}}" data-tool="empty" bindtap="onSelectTool">
          <view class="tool-icon cell-empty"></view>
          <text>橡皮</text>
        </view>
        <view class="tool-btn {{currentTool === 'wall' ? 'active' : ''}}" data-tool="wall" bindtap="onSelectTool">
          <view class="tool-icon cell-wall"></view>
          <text>墙壁</text>
        </view>
        <view class="tool-btn {{currentTool === 'start' ? 'active' : ''}}" data-tool="start" bindtap="onSelectTool">
          <view class="tool-icon cell-start"></view>
          <text>起点</text>
        </view>
        <view class="tool-btn {{currentTool === 'goal' ? 'active' : ''}}" data-tool="goal" bindtap="onSelectTool">
          <view class="tool-icon cell-goal"></view>
          <text>终点</text>
        </view>
      </view>
    </view>

    <!-- 物品工具 -->
    <view class="palette-section">
      <text class="palette-title">物品</text>
      <view class="tool-list">
        <view class="tool-btn {{currentTool === 'conveyor' ? 'active' : ''}}" data-tool="conveyor" bindtap="onSelectTool">
          <view class="tool-icon item-conveyor"></view>
          <text>传送带</text>
        </view>
        <view class="tool-btn {{currentTool === 'spring' ? 'active' : ''}}" data-tool="spring" bindtap="onSelectTool">
          <view class="tool-icon item-spring"></view>
          <text>弹簧</text>
        </view>
        <view class="tool-btn {{currentTool === 'slope' ? 'active' : ''}}" data-tool="slope" bindtap="onSelectTool">
          <view class="tool-icon item-slope"></view>
          <text>斜坡</text>
        </view>
      </view>
    </view>

    <!-- 方向选择器 -->
    <view class="palette-section dir-section" wx:if="{{showDir}}">
      <text class="palette-title">方向</text>
      <view class="dir-pad">
        <view class="dir-btn {{currentDir === 0 ? 'active' : ''}}" data-dir="0" bindtap="onSelectDir">↑</view>
        <view class="dir-row">
          <view class="dir-btn {{currentDir === 3 ? 'active' : ''}}" data-dir="3" bindtap="onSelectDir">←</view>
          <view class="dir-btn {{currentDir === 1 ? 'active' : ''}}" data-dir="1" bindtap="onSelectDir">→</view>
        </view>
        <view class="dir-btn {{currentDir === 2 ? 'active' : ''}}" data-dir="2" bindtap="onSelectDir">↓</view>
      </view>
    </view>
  </view>
</view>
