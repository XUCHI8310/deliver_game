/* ========================================
   关卡编辑器 - 暗色主题
   ======================================== */

.editor-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #0f0f23;
  color: #e0e0e0;
  overflow: hidden;
}

/* ---- 顶部工具栏 ---- */
.top-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #1a1a35;
  border-bottom: 2rpx solid #2a2a4a;
  flex-shrink: 0;
  gap: 16rpx;
}

.name-input {
  flex: 1;
  height: 56rpx;
  background: #252545;
  border: 2rpx solid #3a3a5a;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #e0e0e0;
  min-width: 0;
}

.size-ctrl {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #aaa;
  flex-shrink: 0;
}

.size-ctrl text {
  white-space: nowrap;
}

.picker-val {
  display: inline-block;
  min-width: 48rpx;
  text-align: center;
  height: 48rpx;
  line-height: 48rpx;
  background: #252545;
  border: 2rpx solid #3a3a5a;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #fff;
  padding: 0 10rpx;
}

.top-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.btn-test,
.btn-save {
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
  white-space: nowrap;
}

.btn-test {
  background: #1b5e20;
  color: #a5d6a7;
  border: 2rpx solid #2e7d32;
}

.btn-test:active {
  background: #2e7d32;
}

.btn-save {
  background: #0d47a1;
  color: #90caf9;
  border: 2rpx solid #1565c0;
}

.btn-save:active {
  background: #1565c0;
}

/* ---- 编辑画布 ---- */
.editor-canvas {
  flex: 1;
  width: 100%;
  min-height: 0;
}

/* ---- 底部工具面板 ---- */
.palette {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 16rpx 12rpx;
  background: #1a1a35;
  border-top: 2rpx solid #2a2a4a;
  flex-shrink: 0;
  gap: 16rpx;
  overflow-x: auto;
}

.palette-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.palette-title {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.tool-list {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
}

/* ---- 工具按钮 ---- */
.tool-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 110rpx;
  border-radius: 12rpx;
  background: #252545;
  border: 2rpx solid #3a3a5a;
  transition: all 0.15s;
}

.tool-btn text {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 6rpx;
}

.tool-btn.active {
  background: #2a2a55;
  border-color: #e91e63;
  box-shadow: 0 0 12rpx rgba(233, 30, 99, 0.4);
}

.tool-btn.active text {
  color: #fff;
}

.tool-btn:active {
  transform: scale(0.94);
}

/* ---- 工具图标 (CSS 绘制) ---- */
.tool-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 6rpx;
  position: relative;
}

/* 橡皮 - 空心方格 */
.cell-empty {
  border: 3rpx dashed #888;
  background: transparent;
}

/* 墙壁 - 实心深色块 */
.cell-wall {
  background: #4a4a6a;
  border: 2rpx solid #3a3a5a;
}

/* 起点 - 绿色圆形 */
.cell-start {
  background: #4caf50;
  border-radius: 50%;
  border: 2rpx solid #388e3c;
}

/* 终点 - 红色菱形 */
.cell-goal {
  background: #f44336;
  border: 2rpx solid #d32f2f;
  transform: rotate(45deg);
  border-radius: 4rpx;
  width: 40rpx;
  height: 40rpx;
  margin: 4rpx;
}

/* 传送带 - 蓝色 */
.item-conveyor {
  background: rgba(33, 150, 243, 0.2);
  border: 2rpx solid #2196f3;
}

.item-conveyor::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 15%;
  width: 70%;
  height: 0;
  border-top: 3rpx solid #2196f3;
  transform: translateY(-50%);
}

/* 弹簧 - 橙红色 */
.item-spring {
  background: rgba(255, 87, 34, 0.2);
  border: 2rpx solid #ff5722;
}

.item-spring::after {
  content: '';
  position: absolute;
  top: 20%;
  left: 20%;
  width: 60%;
  height: 60%;
  border-top: 3rpx solid #ff5722;
  border-bottom: 3rpx solid #ff5722;
}

/* 斜坡 - 紫色 */
.item-slope {
  background: rgba(156, 39, 176, 0.2);
  border: 2rpx solid #9c27b0;
  overflow: hidden;
}

.item-slope::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 0;
  border-left: 48rpx solid transparent;
  border-bottom: 48rpx solid rgba(156, 39, 176, 0.35);
}

/* ---- 方向选择器 ---- */
.dir-section {
  min-width: 160rpx;
}

.dir-pad {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.dir-row {
  display: flex;
  gap: 60rpx;
}

.dir-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 10rpx;
  background: #252545;
  border: 2rpx solid #3a3a5a;
  color: #aaa;
  transition: all 0.15s;
}

.dir-btn.active {
  background: #e91e63;
  border-color: #e91e63;
  color: #fff;
  box-shadow: 0 0 10rpx rgba(233, 30, 99, 0.5);
}

.dir-btn:active {
  transform: scale(0.9);
}
