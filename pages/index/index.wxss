/* ===== 页面容器 ===== */
.home-page {
  min-height: 100vh;
  background-color: #0f0f23;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* ===== 标题区域 ===== */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
}

.header .title {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 8rpx;
  text-shadow: 0 4rpx 16rpx rgba(255, 193, 7, 0.4);
}

.header .subtitle {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 4rpx;
}

/* ===== 关卡网格 ===== */
.level-grid {
  height: calc(100vh - 280rpx);
  padding: 20rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-content: flex-start;
}

/* ===== 关卡卡片 ===== */
.level-card {
  position: relative;
  width: 210rpx;
  height: 240rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #1e1e3a, #16162e);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
}

.level-card:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

/* 锁定状态 */
.level-card.locked {
  opacity: 0.4;
  pointer-events: none;
}

.level-card.locked:active {
  transform: none;
}

/* ===== 关卡编号 ===== */
.level-number {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

.level-card.locked .level-number {
  background: linear-gradient(135deg, #3a3a5a, #2a2a4a);
  box-shadow: none;
}

/* ===== 关卡名称 ===== */
.level-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.level-card.locked .level-name {
  color: rgba(255, 255, 255, 0.3);
}

/* ===== 星级评价 ===== */
.level-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.15);
  transition: color 0.3s ease;
}

.star.active {
  color: #ffc107;
  text-shadow: 0 2rpx 8rpx rgba(255, 193, 7, 0.6);
}

/* ===== 锁定图标 ===== */
.lock-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 28rpx;
  opacity: 0.7;
}

/* ===== 关卡编辑按钮 (悬浮) ===== */
.editor-btn {
  position: fixed;
  right: 40rpx;
  bottom: 80rpx;
  height: 88rpx;
  padding: 0 40rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.5);
  z-index: 100;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.editor-btn:active {
  transform: scale(0.93);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.editor-btn text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  letter-spacing: 2rpx;
}
